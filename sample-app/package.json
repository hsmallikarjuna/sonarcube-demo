{
  "name": "sonar-demo-app",
  "version": "1.0.0",
  "description": "Sample Node.js/Express app used to demonstrate SonarQube static analysis in a Jenkins CI/CD pipeline",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "nyc --reporter=lcov --reporter=text mocha test/**/*.test.js --reporter mocha-multi-reporters --reporter-options configFile=.mocha-multi-reporters.json",
    "lint": "echo \"(optional) hook up eslint here\""
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "mocha": "^10.4.0",
    "mocha-junit-reporter": "^2.2.1",
    "mocha-multi-reporters": "^1.5.1",
    "chai": "^4.4.1",
    "supertest": "^6.3.4",
    "nyc": "^15.1.0"
  },
  "license": "MIT"
}